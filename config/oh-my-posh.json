{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "options": {
            "cache_duration": "none",
            "root_icon": "\uf0e7"
          },
          "template": "\uf0e7",
          "foreground": "red",
          "powerline_symbol": "\ue0b0",
          "type": "root",
          "style": "plain"
        },
        {
          "options": {
            "folder_icon": "\uf114 ",
            "folder_separator_icon": "/",
            "home_icon": "\uf46d",
            "style": "agnoster"
          },
          "template": "{{ .Path }}",
          "foreground": "blue",
          "type": "path",
          "style": "plain"
        },
        {
          "options": {
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "github_icon": "\uf408 "
          },
          "template": " on {{ .HEAD }} {{ .BranchStatus }}{{ if .Working.Changed }} \uf044 <red>{{ .Working.String }}</>{{ end }}{{ if and (.Staging.Changed) (.Working.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 <yellow>{{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0}} \uf692 {{ .StashCount }}{{ end }}{{ if gt .WorktreeCount 0}} \uf1bb {{ .WorktreeCount }}{{ end }}",
          "foreground": "green",
          "type": "git",
          "style": "plain",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}yellow{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}red{{ end }}",
            "{{ if gt .Ahead 0 }}green{{ end }}",
            "{{ if gt .Behind 0 }}red{{ end }}"
          ]
        },
        {
          "options": {
            "cache_duration": "none"
          },
          "template": "  {{ if .Unsupported }}\uf071{{ else }}{{ .Full }}{{ end }} ",
          "foreground": "magenta",
          "type": "dotnet",
          "style": "plain"
        }
      ],
      "newline": true
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
       {
          "type": "connection",
          "style": "plain",
          "template": "{{ if eq .Type \"wifi\"}}\udb81\udda9{{ else if eq .Type \"ethernet\"}}\ueba9{{ end }}  "
        },
         {
          "type": "battery",
          "style": "plain",
          "template": "{{ if not .Error }}{{ .Icon }}{{ .Percentage }}{{ end }} ",
          "foreground_templates": [
            "{{if eq \"Charging\" .State.String}}orange{{end}}",
            "{{if eq \"Discharging\" .State.String}}red{end}}",
            "{{if eq \"Full\" .State.String}}green{{end}}"
          ],
          "options": {
            "discharging_icon": "\udb80\udc7e",
            "charging_icon": "\udb82\udc9d",
            "charged_icon": "\udb80\udc84",
            "not_charging_icon": "\udb80\udc79"
          }
        },
        {
          "options": {
            "time_format": "15:04:05"
          },
          "template": "{{ .CurrentDate | date .Format }} ",
          "foreground": "yellow",
          "type": "time",
          "style": "plain"
        },
        {
          "options": {
            "cache_duration": "none"
          },
          "template": "❯",
          "foreground": "green",
          "type": "text",
          "style": "plain"
        }
      ],
      "newline": true
    }
  ],
  "version": 3,
  "final_space": true
}