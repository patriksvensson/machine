                "builtinGlyphs": true,
                "face": "IosevkaTerm Nerd Font",
                "size": 14,
                "weight": "normal"
            },
            "opacity": 98,
            "scrollbarState": "visible",
            "snapOnInput": true,
            "useAcrylic": false
        },
        "list": 
